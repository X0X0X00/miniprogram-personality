.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 60rpx 48rpx;
  text-align: center;
}

.state-icon {
  font-size: 100rpx;
  margin-bottom: 40rpx;
}

.state-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #1a1a1a;
  margin-bottom: 24rpx;
}

.room-code {
  font-size: 120rpx;
  font-weight: 900;
  color: #1a1a1a;
  letter-spacing: 16rpx;
  margin: 32rpx 0;
}

.state-hint {
  font-size: 28rpx;
  color: #888;
  margin-bottom: 40rpx;
}

.loading-dots {
  display: flex;
  gap: 16rpx;
  justify-content: center;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #ccc;
}

.code-input {
  width: 100%;
  height: 120rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 20rpx;
  text-align: center;
  font-size: 64rpx;
  letter-spacing: 16rpx;
  margin: 40rpx 0;
  color: #1a1a1a;
}

.confirm-btn {
  width: 100%;
  height: 96rpx;
  background: #1a1a1a;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
}

.confirm-btn.disabled {
  background: #ccc;
}

.error-text {
  margin-top: 24rpx;
  color: #e85d75;
  font-size: 26rpx;
}

.timeout-hint {
  margin-top: 60rpx;
  font-size: 26rpx;
  color: #888;
}

.link {
  color: #e85d75;
  text-decoration: underline;
}
