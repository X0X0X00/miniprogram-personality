.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 60rpx 48rpx;
}

.hero {
  text-align: center;
  margin-bottom: 60rpx;
}

.title {
  font-size: 56rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 4rpx;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: #888;
}

.desc-card {
  background: #f7f7f7;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 80rpx;
  width: 100%;
}

.desc-text {
  font-size: 30rpx;
  color: #555;
  line-height: 1.8;
}

.start-btn {
  width: 100%;
  height: 96rpx;
  background: #1a1a1a;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  letter-spacing: 4rpx;
}

.footer-note {
  margin-top: 40rpx;
  font-size: 24rpx;
  color: #bbb;
}
