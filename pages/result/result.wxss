.container {
  padding: 60rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.header {
  text-align: center;
  margin-bottom: 60rpx;
}

.code {
  font-size: 32rpx;
  color: #aaa;
  letter-spacing: 8rpx;
  font-weight: 300;
  margin-bottom: 16rpx;
}

.name {
  font-size: 72rpx;
  font-weight: 700;
  color: #1a1a1a;
  letter-spacing: 6rpx;
}

.tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 48rpx;
  justify-content: center;
}

.tag {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 28rpx;
  border-radius: 16rpx;
  min-width: 140rpx;
}

.tag-h {
  background: #1a1a1a;
  color: #fff;
}

.tag-l {
  background: #f0f0f0;
  color: #555;
}

.tag-label {
  font-size: 22rpx;
  opacity: 0.7;
  margin-bottom: 4rpx;
}

.tag-value {
  font-size: 26rpx;
  font-weight: 600;
}

.desc-card {
  background: #f7f7f7;
  border-radius: 24rpx;
  padding: 48rpx;
  margin-bottom: 60rpx;
  width: 100%;
}

.desc-text {
  font-size: 30rpx;
  color: #444;
  line-height: 1.9;
}

.save-btn {
  width: 100%;
  height: 96rpx;
  background: #1a1a1a;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  margin-bottom: 24rpx;
}

.retry-btn {
  width: 100%;
  height: 96rpx;
  background: transparent;
  color: #888;
  font-size: 30rpx;
  border-radius: 48rpx;
  border: 2rpx solid #e0e0e0;
}
